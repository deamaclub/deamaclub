// Deamaclub Prisma schema
// PostgreSQL backed via DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase pgbouncer port 6543) — used by the app at runtime
  url       = env("DATABASE_URL")
  // Direct connection (Supabase port 5432) — used by `prisma migrate` for DDL
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  // Email is optional for public users (account signup doesn't require one).
  // Still unique when set so admins can keep using email-based login.
  email     String?  @unique
  // Public-facing handle. Required, unique, lowercase. Used as the
  // primary login identifier for non-admin accounts.
  username  String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts             Post[]
  comments          Comment[]
  postLikes         PostLike[]
  commentLikes      CommentLike[]
  // Notifications addressed to this user
  notifications     Notification[] @relation("notificationRecipient")
  // Notifications this user triggered (e.g. they liked or replied)
  actorNotifications Notification[] @relation("notificationActor")
}

enum Role {
  ADMIN
  EDITOR
  USER
}

model Category {
  id        String  @id @default(cuid())
  name      String  @unique
  slug      String  @unique
  order     Int     @default(0)
  posts     Post[]
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("PostTags")
}

model Post {
  id            String     @id @default(cuid())
  slug          String     @unique
  title         String
  description   String?
  // Optional per-post SEO overrides. When null, metadata is auto-derived
  // from title + description at render time.
  metaTitle       String?
  metaDescription String?
  focusKeywords   String?  // comma-separated
  embedUrl      String?
  videoUrl      String?
  thumbnailUrl  String?
  durationSec   Int?
  published     Boolean    @default(false)
  trending      Boolean    @default(false)
  viewCount     Int        @default(0)
  // Denormalised like count for fast list-page reads. Source of truth
  // is PostLike rows; this column is updated in the like API transaction.
  likeCount     Int        @default(0)
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  authorId      String?
  author        User?      @relation(fields: [authorId], references: [id])
  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [id])
  tags          Tag[]      @relation("PostTags")
  comments      Comment[]
  views         View[]
  likes         PostLike[]

  @@index([published, publishedAt(sort: Desc)])
  @@index([categoryId, published, publishedAt(sort: Desc)])
  @@index([trending, published])
  @@index([title])
}

model View {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  ipHash    String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  // userId is nullable so legacy comments (string author only) still
  // resolve. New comments require an account so this is set in practice.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // Cached display name (kept even if user deletes account).
  author    String
  body      String
  // Threading: parentId NULL = top-level, otherwise points at parent comment.
  parentId  String?
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  // Denormalised like count for fast read.
  likeCount Int        @default(0)
  likes     CommentLike[]
  notifications Notification[]
  approved  Boolean    @default(true)
  createdAt DateTime   @default(now())

  @@index([postId, parentId, createdAt(sort: Desc)])
  @@index([userId])
  @@index([parentId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([userId])
}

enum NotificationType {
  COMMENT_REPLY
  COMMENT_LIKE
}

model Notification {
  id          String   @id @default(cuid())
  type        NotificationType
  recipientId String
  recipient   User     @relation("notificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User     @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  commentId   String?
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  // Cache of the post slug at notification creation time so we can
  // build a link target without a JOIN every poll.
  postSlug    String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, read, createdAt(sort: Desc)])
}
