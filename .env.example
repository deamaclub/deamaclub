# =========================================================================
# Deamaclub environment variables
# Copy this file to `.env` (local dev) or `.env.production` on the server.
# =========================================================================

# Public site origin. Used for OG tags, sitemap, share buttons.
NEXT_PUBLIC_SITE_URL="https://deamaclub.com"

# --- Database (Supabase) --------------------------------------------------
# Two connection strings from Supabase Settings → Database → Connection string:
#
#   DATABASE_URL = the POOLER / Transaction mode URI (port 6543).
#                  Must end with ?pgbouncer=true&connection_limit=1
#                  The running Next.js app uses this.
#
#   DIRECT_URL   = the SESSION mode URI (port 5432).
#                  Used by `prisma migrate deploy` for DDL.
#
# Example (replace with your real values):
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- NextAuth -------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING"
NEXTAUTH_URL="https://deamaclub.com"

# --- Initial admin account (only used by `npm run db:seed`) ---------------
ADMIN_EMAIL="admin@deamaclub.com"
ADMIN_PASSWORD="CHANGE_ME_BEFORE_SEEDING"

# --- Cloudflare media -----------------------------------------------------
# Account ID is in the right sidebar of any Cloudflare dashboard page.
CLOUDFLARE_ACCOUNT_ID=""

# Token with "Cloudflare Images: Edit" permission — used by the admin
# thumbnail uploader. Without it the app falls back to /public/uploads/.
CLOUDFLARE_IMAGES_TOKEN=""

# Token with "Stream: Edit" permission — required for TUS direct uploads
# from the admin form. Create at:
#   https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_STREAM_TOKEN=""

# --- Privacy salt for view-dedup hashing ----------------------------------
VIEW_HASH_SALT="CHANGE_ME_random_string_for_ip_hashing"

# --- Analytics / Ads (optional placeholders) ------------------------------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_RAPTIVE_SITE_ID=""
