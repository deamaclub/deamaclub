# =========================================================================
# Deamaclub environment variables
# Copy this file to `.env` (local dev) or `.env.production` on the server.
# =========================================================================

# Public site origin. Used for OG tags, sitemap, share buttons.
NEXT_PUBLIC_SITE_URL="https://deamaclub.com"

# --- Database (Supabase) --------------------------------------------------
# Open the Supabase dashboard → "Connect" → pick "Session pooler (Shared)"
# (the IPv4-compatible option). Copy that URL twice — once for each var.
#
# Username format: postgres.<project-ref>  (the dot matters)
# Pooler hostname format: aws-1-<region>.pooler.supabase.com  (note "aws-1",
# not "aws-0" — the exact prefix varies by project, copy from the dashboard)
# Region examples: us-west-2, us-east-1, eu-central-1, ap-southeast-1
#
# Example (replace PROJECT_REF, PASSWORD, REGION with your real values):
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# If you have Supabase's dedicated IPv4 add-on enabled, you can use the
# higher-throughput Transaction pooler for DATABASE_URL:
#   "postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# Leave DIRECT_URL on the Session pooler either way — Prisma migrate needs
# a session-mode connection for DDL.

# --- NextAuth -------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING"
NEXTAUTH_URL="https://deamaclub.com"

# --- Initial admin account (only used by `npm run db:seed`) ---------------
ADMIN_EMAIL="admin@deamaclub.com"
ADMIN_PASSWORD="CHANGE_ME_BEFORE_SEEDING"

# --- Bunny Stream (video hosting) -----------------------------------------
# Sign up at bunny.net → Stream → create a library. Then on the library's
# "API" page copy:
#   * Library ID            (numeric, top of the page)
#   * API Key               ("API Key" field)
#   * CDN Hostname          (the vz-...b-cdn.net hostname)
BUNNY_STREAM_LIBRARY_ID=""
BUNNY_STREAM_API_KEY=""
BUNNY_STREAM_PULL_ZONE=""

# Thumbnail uploads (custom images): the admin form falls back to writing
# to /public/uploads/ on the server, which nginx serves with long cache.
# No external storage service required for an MVP.

# --- Privacy salt for view-dedup hashing ----------------------------------
VIEW_HASH_SALT="CHANGE_ME_random_string_for_ip_hashing"

# --- Analytics / Ads (optional placeholders) ------------------------------
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification token (the `content="..."` value
# from the HTML-tag verification method). Setting this injects the
# <meta name="google-site-verification"> tag in the page head.
NEXT_PUBLIC_GSC_VERIFICATION=""

# Google AdSense publisher ID (looks like "ca-pub-XXXXXXXXXXXXXXXX").
# Setting this injects the AdSense loader script in the page head and
# enables <AdSlot/> to render real ad units when their per-zone slot ID
# is also set (see below).
NEXT_PUBLIC_ADSENSE_CLIENT=""

# After AdSense approves the site, create one Ad Unit per zone in the
# AdSense dashboard and paste the numeric slot ID for each here. Zones
# without a slot ID continue to render the placeholder.
#   leaderboard-top   home-sidebar-1   home-sidebar-2
#   article-top       article-mid      article-bottom
#   video-sidebar-1   video-sidebar-2  search-sidebar-1
#   cat-news-sidebar-1 ...  cat-celebrity-sidebar-2
#   infeed-0          infeed-1         infeed-2 ...
NEXT_PUBLIC_ADSENSE_SLOT_LEADERBOARD_TOP=""
NEXT_PUBLIC_ADSENSE_SLOT_HOME_SIDEBAR_1=""
NEXT_PUBLIC_ADSENSE_SLOT_HOME_SIDEBAR_2=""
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_TOP=""
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_MID=""
NEXT_PUBLIC_ADSENSE_SLOT_ARTICLE_BOTTOM=""
NEXT_PUBLIC_ADSENSE_SLOT_VIDEO_SIDEBAR_1=""
NEXT_PUBLIC_ADSENSE_SLOT_VIDEO_SIDEBAR_2=""
NEXT_PUBLIC_ADSENSE_SLOT_SEARCH_SIDEBAR_1=""
