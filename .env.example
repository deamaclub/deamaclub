# =========================================================================
# Deamaclub environment variables
# Copy this file to `.env` (local dev) or `.env.production` on the server.
# =========================================================================

# Public site origin. Used for OG tags, sitemap, share buttons.
NEXT_PUBLIC_SITE_URL="https://deamaclub.com"

# PostgreSQL connection string.
# Local dev: postgresql://USER:PASS@localhost:5432/deamaclub?schema=public
DATABASE_URL="postgresql://deamaclub:CHANGE_ME@localhost:5432/deamaclub?schema=public"

# --- NextAuth -------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_A_LONG_RANDOM_STRING"
NEXTAUTH_URL="https://deamaclub.com"

# --- Initial admin account (only used by `npm run db:seed`) ---------------
ADMIN_EMAIL="admin@deamaclub.com"
ADMIN_PASSWORD="CHANGE_ME_BEFORE_SEEDING"

# --- Cloudflare media (optional but recommended) --------------------------
CLOUDFLARE_ACCOUNT_ID=""
# Cloudflare Images token with "Images: Edit" permission
CLOUDFLARE_IMAGES_TOKEN=""
# Cloudflare Stream token (if/when wiring direct video uploads)
CLOUDFLARE_STREAM_TOKEN=""

# --- Privacy salt for view dedup hashing ----------------------------------
VIEW_HASH_SALT="CHANGE_ME_random_string_for_ip_hashing"

# --- Analytics / Ads (optional placeholders) ------------------------------
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_RAPTIVE_SITE_ID=""
